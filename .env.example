# Example environment variables for Supabase (Vite expects VITE_ prefix)
# Copy this file to .env.local (or set variables in your deployment) and fill values

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_CONEKTA_PUBLIC_KEY=key_xxxxxxxxxxxxxxxxxxxxx

# Optional: service role key for server-side operations (DO NOT expose in client builds)
# VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# If you need a server-side privileged upsert, run a secure backend using the service_role key
# (do not expose the service_role key to clients). For client-only flows use the anon key.
